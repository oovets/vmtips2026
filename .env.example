# PostgreSQL (lokal Docker enligt docker-compose.yml)
DATABASE_URL="postgresql://vmtips:vmtips@localhost:5439/vmtips?schema=public"

# Hemlighet för att signera session-cookies (byt till valfri lång slumpsträng)
SESSION_SECRET="change-me-to-a-long-random-string-please"

# football-data.org API-nyckel (gratis: https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=""

# Matchdetaljer (målgörare, kort, straffar) på Matcher-sidan. Gratisnivån hos
# football-data.org saknar detta — peka på ett API som har det. URL-mall med {id}
# (fixture-id). Default = football-data.org:s match-endpoint (events på betald nivå).
# MATCH_DETAIL_ENDPOINT="https://api.football-data.org/v4/matches/{id}"
# Egen nyckel/auth-header om detaljerna hämtas från ett annat API än ovan:
# MATCH_DETAIL_API_KEY=""
# MATCH_DETAIL_AUTH_HEADER="X-Auth-Token"

# Skyddar cron-endpointen /api/cron/sync-results mot obehöriga anrop
CRON_SECRET="change-me-cron-secret"

# Admin-PIN för /admin (manuell resultatinmatning, trigga sync)
ADMIN_PIN="4242"

# När tipsen låses (ISO). Default = första avsparken. Sätt i framtiden för att testa öppet läge.
LOCK_AT="2026-06-11T18:00:00Z"

# Anthropic API-nyckel för AI-analysknappen (hämta på console.anthropic.com)
ANTHROPIC_API_KEY=""
