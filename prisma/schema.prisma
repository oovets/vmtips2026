// VM-tips 2026 — Prisma schema
// Datamodell för delad liga: lag, grupper, matcher och spelarnas tips.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Stage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

model League {
  id        String   @id @default(uuid())
  name      String
  joinCode  String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String   @id @default(uuid())
  displayName String
  pinHash     String
  isAdmin     Boolean  @default(false)
  submitted   Boolean  @default(false) // har spelaren lämnat in sitt lag?
  league      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId    String

  matchPredictions   MatchPrediction[]
  groupPredictions   GroupPrediction[]
  bracketPredictions BracketPrediction[]
  score              Score?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, displayName])
}

model Group {
  id      String  @id // "A".."L"
  letter  String  @unique
  teams   Team[]
  matches Match[]
}

model Team {
  id        String  @id @default(uuid())
  name      String  @unique // matchar openfootball-namn, t.ex. "Sweden"
  code      String // FIFA 3-bokstav, t.ex. "SWE"
  flag      String // emoji-flagga
  fifaRank  Int     @default(99) // för tiebreak av bästa treor
  group     Group   @relation(fields: [groupId], references: [id])
  groupId   String

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  wonMatches  Match[] @relation("WinnerTeam")
}

model Match {
  id          String      @id @default(uuid())
  matchNumber Int         @unique // 1..104, används av slutspelsträdets W##-referenser
  stage       Stage
  round       String // "Matchday 1", "Round of 32", ...
  group       Group?      @relation(fields: [groupId], references: [id])
  groupId     String?
  kickoff     DateTime
  venue       String

  // Gruppmatcher har lag direkt. Slutspelsmatcher har platshållare tills facit finns.
  homeTeam   Team?   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId String?
  awayTeam   Team?   @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId String?
  homeSlot   String? // "2A", "3A/B/C/D/F", "W74" osv.
  awaySlot   String?

  status     MatchStatus @default(SCHEDULED)
  homeScore  Int?
  awayScore  Int?
  // Vinnare (slutspel; kan avgöras på straffar trots oavgjort i ordinarie tid)
  winner     Team?       @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  winnerTeamId String?
  apiId      String? // football-data.org fixture-id för synk

  matchPredictions MatchPrediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Exakt resultat-tips för en gruppmatch
model MatchPrediction {
  id       String @id @default(uuid())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId  String
  predHome Int
  predAway Int

  @@unique([userId, matchId])
}

// Spelarens rankning av en grupp (1:a–4:a)
model GroupPrediction {
  id          String @id @default(uuid())
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  groupId     String
  rank1TeamId String
  rank2TeamId String
  rank3TeamId String
  rank4TeamId String

  @@unique([userId, groupId])
}

// Spelarens slutspelsträd: per slutspelsmatch vilka två lag som möts + vem som går vidare.
// De 8 bästa treorna fångas implicit av vilka treor som dyker upp i R32-matcherna (73–88).
model BracketPrediction {
  id            String @id @default(uuid())
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  matchNumber   Int // 73..104
  team1Id       String?
  team2Id       String?
  winnerTeamId  String?

  @@unique([userId, matchNumber])
}

// Cachelagrad totalpoäng + uppdelning per spelare (räknas om vid varje resultatsynk)
model Score {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @unique
  total      Int      @default(0)
  breakdown  Json     @default("{}")
  updatedAt  DateTime @updatedAt
}
