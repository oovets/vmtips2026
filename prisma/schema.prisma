// VM-tips 2026 — Prisma schema
// Datamodell för delad liga: lag, grupper, matcher och spelarnas tips.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TippingMode {
  EXACT // tippa exakt resultat (default)
  X12   // tippa bara 1 / X / 2
}

enum Stage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

model League {
  id          String      @id @default(uuid())
  name        String
  joinCode    String      @unique
  tippingMode TippingMode @default(EXACT)
  users       User[]
  quizzes     Quiz[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model User {
  id          String   @id @default(uuid())
  displayName String
  pinHash     String
  loginCode   String   @unique // personlig inloggningskod, visas för spelaren
  isAdmin     Boolean  @default(false)
  submitted   Boolean  @default(false)
  league      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId    String

  // Frivilligt skyttekung-tips (VM:s skyttekung). Inte ett krav för inlämning.
  topScorerPlayer String? // fritext, spelarnamn
  topScorerTeamId String? // valfritt lag (referens till Team.id, ej FK för enkelhet)

  matchPredictions   MatchPrediction[]
  groupPredictions   GroupPrediction[]
  bracketPredictions BracketPrediction[]
  guestbookEntries   GuestbookEntry[]
  score              Score?
  sessionLogs        SessionLog[]
  interactionEvents  InteractionEvent[]
  quizzesCreated     Quiz[]              @relation("QuizCreator")
  quizzesOpponent    Quiz[]              @relation("QuizOpponent")
  quizResults        QuizResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, displayName])
}

model Group {
  id      String  @id // "A".."L"
  letter  String  @unique
  teams   Team[]
  matches Match[]
}

model Team {
  id         String  @id @default(uuid())
  name       String  @unique // matchar openfootball-namn, t.ex. "Sweden"
  code       String // FIFA 3-bokstav, t.ex. "SWE"
  flag       String // emoji-flagga
  fifaRank   Int     @default(99) // för tiebreak av bästa treor
  recentForm Json    @default("[]") // [{opp, oppFlag, score, result, date}]
  group      Group   @relation(fields: [groupId], references: [id])
  groupId    String

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  wonMatches  Match[] @relation("WinnerTeam")
}

model Match {
  id          String      @id @default(uuid())
  matchNumber Int         @unique // 1..104, används av slutspelsträdets W##-referenser
  stage       Stage
  round       String // "Matchday 1", "Round of 32", ...
  group       Group?      @relation(fields: [groupId], references: [id])
  groupId     String?
  kickoff     DateTime
  venue       String
  channel     String? // svensk sändningskanal, t.ex. "SVT", "TV4", "Viaplay" (null = okänd)

  // Gruppmatcher har lag direkt. Slutspelsmatcher har platshållare tills facit finns.
  homeTeam   Team?   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId String?
  awayTeam   Team?   @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId String?
  homeSlot   String? // "2A", "3A/B/C/D/F", "W74" osv.
  awaySlot   String?

  status     MatchStatus @default(SCHEDULED)
  homeScore  Int?
  awayScore  Int?
  // Vinnare (slutspel; kan avgöras på straffar trots oavgjort i ordinarie tid)
  winner     Team?       @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  winnerTeamId String?
  apiId      String? // football-data.org fixture-id för synk
  // Matchdetaljer (målgörare, kort, straffsparksläggning) hämtas via MATCH_DETAIL_ENDPOINT.
  // Form: { goals:[{side,player,minute,type,assist}], cards:[{side,player,minute,card}], shootout:{home,away}|null }
  details    Json? // null = inte hämtad ännu

  matchPredictions MatchPrediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MatchPrediction {
  id          String  @id @default(uuid())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  match       Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId     String
  predHome    Int?    // null i 1X2-läge
  predAway    Int?    // null i 1X2-läge
  predOutcome String? // "1" | "X" | "2" — används i 1X2-läge

  @@unique([userId, matchId])
}

// Spelarens rankning av en grupp (1:a–4:a)
model GroupPrediction {
  id          String @id @default(uuid())
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  groupId     String
  rank1TeamId String
  rank2TeamId String
  rank3TeamId String
  rank4TeamId String

  @@unique([userId, groupId])
}

// Spelarens slutspelsträd: per slutspelsmatch vilka två lag som möts + vem som går vidare.
// De 8 bästa treorna fångas implicit av vilka treor som dyker upp i R32-matcherna (73–88).
model BracketPrediction {
  id            String @id @default(uuid())
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  matchNumber   Int // 73..104
  team1Id       String?
  team2Id       String?
  winnerTeamId  String?

  @@unique([userId, matchNumber])
}

// Turneringsövergripande facit/fakta (nyckel-värde). Används bl.a. för VM:s
// skyttekung ("topScorer"): value = spelarnamn (facit som admin fyller i).
model TournamentFact {
  key       String   @id // t.ex. "topScorer"
  value     String?
  teamId    String? // valfri lag-koppling (t.ex. skyttekungens lag)
  updatedAt DateTime @updatedAt
}

// Klotterplank: kort, publikt meddelande på översikten. Frivillig koppling till
// inloggad spelare (userId), annars fritt angivet visningsnamn.
model GuestbookEntry {
  id        String   @id @default(uuid())
  name      String // visningsnamn (inloggad spelares namn eller fritt angivet)
  message   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?

  @@index([createdAt])
}

// Cachelagrad totalpoäng + uppdelning per spelare (räknas om vid varje resultatsynk)
model Score {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @unique
  total      Int      @default(0)
  breakdown  Json     @default("{}")
  // Placering i ligan (lägst = bäst). previousRank speglar standingen vid
  // föregående omräkning, så trenden upp/ner kan härledas mot currentRank.
  previousRank  Int?
  currentRank   Int?
  rankUpdatedAt DateTime?
  updatedAt  DateTime @updatedAt
}

// --- Användarsessions-loggning (alla besökare, även utloggade) ---

enum InteractionType {
  PAGEVIEW
  CLICK
  INPUT_FOCUS
  SUBMIT
  NAV
}

// En besökarsession. sessionId genereras på klienten (UUID i localStorage/cookie)
// och är stabil över sidladdningar. userId fylls i server-side när besökaren är
// inloggad (annars anonym). IP/reverse-DNS/GeoIP berikas vid första sikten.
model SessionLog {
  id          String   @id @default(uuid())
  sessionId   String   @unique // klientgenererad UUID
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?

  ip          String?
  ipReverse   String? // reverse DNS (PTR), null om okänd/misslyckad
  // GeoIP (ip-api.com) — alla nullable, lagras bara om uppslaget lyckas
  country     String?
  countryCode String?
  region      String?
  city        String?
  lat         Float?
  lon         Float?
  isp         String?
  org         String?
  asn         String? // ip-api "as"-fält

  userAgent   String?
  referrer    String? // document.referrer vid första sikten
  landingPath String? // första route besökaren landade på

  firstSeen   DateTime @default(now())
  lastSeen    DateTime @updatedAt

  events      InteractionEvent[]

  @@index([userId])
  @@index([lastSeen])
}

// En enskild, meningsfull UI-interaktion eller sidvisning.
model InteractionEvent {
  id          String          @id @default(uuid())
  session     SessionLog      @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  sessionId   String
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?

  type        InteractionType
  path        String? // aktuell route när händelsen inträffade
  targetTag   String? // t.ex. "button", "a"
  targetText  String? // trunkerad synlig text/aria-label (max 200 tecken)
  targetId    String? // elementets id eller name
  selector    String? // lättviktig CSS-selektor-väg
  elementLabel String? // aria-label/title/role-baserad etikett
  x           Int?
  y           Int?
  metadata    Json?

  createdAt   DateTime        @default(now())

  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}

enum QuizKind {
  DAILY
  DUEL
}

// En quiz-instans (frågeset). questions innehåller FULLA frågor med facit — serveras aldrig rått.
model Quiz {
  id          String       @id @default(uuid())
  league      League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId    String
  kind        QuizKind
  seed        String
  questions   Json
  createdBy   User?        @relation("QuizCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  opponent    User?        @relation("QuizOpponent", fields: [opponentId], references: [id], onDelete: SetNull)
  opponentId  String?
  dayKey      String? // Stockholm-datum för DAILY (null för DUEL)
  results     QuizResult[]
  createdAt   DateTime     @default(now())

  @@unique([leagueId, kind, dayKey])
}

// En spelares resultat på en quiz. Varje spelare spelar en given quiz exakt en gång.
model QuizResult {
  id           String   @id @default(uuid())
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  score        Int
  correctCount Int
  totalMs      Int
  // Anti-cheat: hur många gånger spelaren lämnade rutan (tabbade/bytte fönster)
  // och total tid borta. Visas som ⚠️-flagga för ligan.
  awayCount    Int      @default(0)
  awayMs       Int      @default(0)
  finishedAt   DateTime @default(now())

  @@unique([quizId, userId])
}
